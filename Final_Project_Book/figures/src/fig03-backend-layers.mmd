flowchart TB
  Request["HTTP request"]
  Global["Global middleware\nrate limit → CORS → body parsers"]
  Route["Route boundary\nprotect / validation / Multer → route"]
  Controller["Controller\nHTTP translation; sometimes direct model access"]
  Service["Services and domain engines\nOCR, findings, agents, imports, forecasts"]
  Utility["Utilities / schemas\ncalculations, normalization, validation"]
  Model["Mongoose models"]
  Mongo[(MongoDB)]
  Local["Local filesystem + OCR subprocesses"]
  External["Claude/Ollama, Google, data.gov.il"]
  Shape["Serializers / DTO shaping"]
  Response["JSON, file download, or SSE response"]

  Request --> Global --> Route --> Controller
  Controller --> Service
  Controller --> Model
  Service --> Utility
  Service --> Model --> Mongo
  Service --> Local
  Service --> External
  Controller --> Shape --> Response
  Service --> Shape
