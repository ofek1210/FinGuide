# Server Configuration
# חייב להתאים ל-proxy ב-frontend/vite.config.ts (5001 אם פורט 5000 תפוס)
PORT=5001
NODE_ENV=development

# MongoDB Configuration
# Local: mongodb://localhost:27017/finguide
# Atlas: mongodb+srv://username:password@cluster.mongodb.net/finguide
MONGODB_URI=mongodb://localhost:27017/finguide

# JWT Configuration
JWT_SECRET=your-super-secret-key-change-this-in-production
JWT_EXPIRE=7d

# Client URL (for CORS)
CLIENT_URL=http://localhost:5173
APP_PUBLIC_URL=http://localhost:5173

# Google OAuth (Web Client ID)
# ב-Google Cloud Console: Credentials → ה-Client ID → Authorized JavaScript origins
# הוסף בדיוק: http://localhost:5173 ו־http://127.0.0.1:5173 (ובפרוד את ה-URL של האתר)
GOOGLE_CLIENT_ID=757872744940-rvibdtmd65cif13ia19tm78npjdn8i7l.apps.googleusercontent.com
# OAuth Web client secret — required for Gmail import (Authorization code flow)
GOOGLE_CLIENT_SECRET=
# Optional dedicated key for encrypting stored Gmail tokens (falls back to JWT_SECRET)
GOOGLE_TOKEN_ENCRYPTION_KEY=

# Ollama (מודל שפה מקומי)
# להתקנה: https://ollama.com | ollama pull llama3.1:8b
# מודלים טובים לעברית: llama3.1:8b, qwen2.5:7b, mistral:7b
OLLAMA_URL=http://localhost:11434
OLLAMA_MODEL=llama3.1:8b

# File Upload (גודל מקסימלי ב-MB)
MAX_UPLOAD_SIZE_MB=10

# Payslip extraction — legacy (OCR/regex, חינם) או vision (Claude Vision, בתשלום)
# PAYSLIP_EXTRACTION_MODE=legacy
# PAYSLIP_EXTRACTION_MODE=vision
# ANTHROPIC_API_KEY=sk-ant-...
# PAYSLIP_VISION_MODEL=claude-haiku-4-5
# OCR_PDF_PAGES_MODE=first
# LLM_MAX_CALLS=20
# LLM_TOKEN_BUDGET=100000

# Password reset
PASSWORD_RESET_EXPIRE_MINUTES=15

# SMTP
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM=

# Finq — leading pension funds market data
FINQ_AUTH_TOKEN=
FINQ_ENABLED=true
FINQ_CACHE_TTL_MS=21600000
FINQ_API_BASE_URL=https://api.finqai.co.il/v1
# Optional: finqRank | yield36Months | yield12Months | avgAnnualManagementFee
FINQ_PENSION_SORT=yield36Months

# Pensia-Net (data.gov.il) — government pension market data + monthly cron
PENSIANET_ENABLED=true
PENSIANET_CRON_ENABLED=true
PENSIANET_CRON_SCHEDULE=0 2 18 * *
PENSIANET_CRON_TZ=Asia/Jerusalem
PENSIANET_RESOURCE_ID=6d47d6b5-cb08-488b-b333-f1e717b1e1bd

# Gov market sync — Pensia-Net + Gemel-Net + Bituah-Net (data.gov.il or local CSV in backend/data/gov/)
GOV_MARKET_CRON_ENABLED=true
GOV_MARKET_CRON_SCHEDULE=0 2 18 * *
GOV_MARKET_CRON_TZ=Asia/Jerusalem
# GOV_CKAN_URL=https://data.gov.il/api/3/action
GEMELNET_ENABLED=true
# data.gov.il "gemelnet" package — resource "נתוני הגמל נט לשנים 2024-היום" (updated by CMA)
GEMELNET_RESOURCE_ID=a30dcbea-a1d2-482c-ae29-8f781f5025fb
# GEMELNET_LOCAL_CSV=gemel-net.csv
BITUAHNET_ENABLED=true
# BITUAHNET_RESOURCE_ID=
# BITUAHNET_LOCAL_CSV=bituah-net.csv

# Insurance pricing — local CSV/Excel only (do NOT scrape comparison sites; CAPTCHA protected)
INSURANCE_PRICING_LOCAL_ONLY=true
# INSURANCE_PRICING_CSV=pricing-benchmark.csv
# INSURANCE_PRICING_XLSX=pricing-benchmark.xlsx
# INSURANCE_PRICING_SOURCE_NAME=FinGuide Insurance Pricing Benchmark (Representative Sample)
# INSURANCE_PRICING_SOURCE_DATE=2026-01
# INSURANCE_PRICING_SOURCE_URL=
# INSURANCE_PRICING_COLLECTION_METHOD=Curated representative samples from published market surveys — not live insurer quotes

# Insurance gov service index — local CSV preferred; remote fetch opt-in only
INSURANCE_GOV_ENABLED=false
INSURANCE_GOV_REMOTE_FETCH=false
# INSURANCE_GOV_CACHE_TTL_MS=86400000
