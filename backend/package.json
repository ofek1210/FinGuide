{
  "name": "finguide-backend",
  "version": "1.0.0",
  "description": "Backend API for FinGuide - Payroll Analysis Platform",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js",
    "test": "npm run test:all",
    "test:all": "jest --runInBand",
    "test:unit": "jest --runInBand --testMatch '**/tests/unit/**/*.test.js' --testMatch '**/__tests__/**/*.test.js'",
    "test:integration": "jest --runInBand --testMatch '**/tests/integration/**/*.test.js'",
    "test:watch": "jest --watch",
    "reprocess:payslips": "node scripts/reprocessPayslips.js",
    "seed:test-account": "node scripts/seedTestAccount.js",
    "sync:pensianet": "node scripts/syncPensiaNet.js",
    "sync:pensianet-tracks": "node scripts/syncPensiaNetTrackMonthly.js --commit --samples=3",
    "sync:pensianet-tracks:dry": "node scripts/syncPensiaNetTrackMonthly.js",
    "import:pensianet-cohort": "node scripts/importPensiaNetCohortAnnual.js",
    "sync:gov": "node scripts/syncGovMarket.js",
    "generate:insurance-samples": "node scripts/generateInsuranceCalculatorSamples.js",
    "parse:pension": "node scripts/parsePensionUpload.js",
    "validate:benchmark-tables": "node scripts/validateBenchmarkTables.js",
    "eval:ocr": "node scripts/evalOcr.js",
    "eval:vision": "node scripts/evalVisionPayslips.js",
    "eval:findings": "node scripts/evalFindings.js",
    "eval:ai-routing": "node scripts/evalAiRouting.js",
    "bench:upload-latency": "node scripts/benchUploadLatency.js",
    "eval:ocr-path3": "node scripts/evalOcrPath3.js",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write \"**/*.{js,json,md}\"",
    "format:check": "prettier --check \"**/*.{js,json,md}\""
  },
  "keywords": [
    "payroll",
    "salary",
    "analysis",
    "api"
  ],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "@anthropic-ai/sdk": "^0.97.1",
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "express-rate-limit": "^7.1.5",
    "express-validator": "^7.3.1",
    "finguide-monorepo": "file:..",
    "google-auth-library": "^9.15.1",
    "googleapis": "^173.0.0",
    "heic-convert": "^2.1.0",
    "jsonwebtoken": "^9.0.2",
    "mongoose": "^8.0.3",
    "multer": "^1.4.5-lts.1",
    "node-cron": "^4.5.0",
    "nodemailer": "^8.0.1",
    "pdf-parse": "^1.1.4",
    "sharp": "^0.34.5",
    "uuid": "^13.0.0",
    "xlsx": "^0.18.5",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/jest": "^30.0.0",
    "eslint": "^8.57.1",
    "eslint-config-airbnb-base": "^15.0.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-import": "^2.32.0",
    "jest": "^30.2.0",
    "jest-environment-node": "^30.2.0",
    "mongodb-memory-server": "^11.0.1",
    "nodemon": "^3.0.2",
    "pdf-lib": "^1.17.1",
    "prettier": "^3.8.1",
    "supertest": "^7.2.2"
  }
}
